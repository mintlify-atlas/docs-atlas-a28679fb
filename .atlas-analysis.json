    ]
  },
  "keyFeatures": [
    "Auto-fill form inputs with user data from Zenfi API",
    "Track lead conversion events (register, clicks, form submissions)",
    "Track lead abortion events (rejections, declined offers)",
    "Automatic page view tracking",
    "Cookie-based user identity management across domains",
    "Support for both Node.js and browser environments",
    "Flexible target configuration with custom selectors and strategies",
    "Before and after action hooks for custom behavior"
  ],
  "publicApiSurface": [
    "new ZenfiSDK({ partnerName, cookiesDomain, targets })",
    "fetchData()",
    "fillTargets()",
    "trackConversion(name, properties)",
    "trackAbortion(name, properties)",
    "trackPageView()",
    "initPageViewsTracking()"
  ]
}
