        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/authentication",
              "concepts/form-autofill",
              "concepts/event-tracking",
              "concepts/cookies"
            ]
          },
          {
            "group": "Guides",
