      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core API",
            "pages": [
              "api/constructor",
              "api/fetch-data",
              "api/fill-targets"
            ]
          },
          {
            "group": "Event Tracking",
            "pages": [
